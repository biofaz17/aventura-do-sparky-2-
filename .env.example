# Copie este arquivo como .env.local e preencha com seus valores

# Supabase (Banco de Dados)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Opcional: Mercado Pago (se usar pagamentos)
# VITE_MERCADO_PAGO_PUBLIC_KEY=sua-chave-publica

# Opcional: Google Generative AI
# VITE_GOOGLE_GENAI_API_KEY=sua-chave-aqui
